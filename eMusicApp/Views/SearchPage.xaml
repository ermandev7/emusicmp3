<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             xmlns:models="clr-namespace:eMusicApp.Models"
             xmlns:views="clr-namespace:eMusicApp.Views"
             xmlns:skeleton="clr-namespace:Maui.Skeleton;assembly=Maui.Skeleton"
             x:Class="eMusicApp.Views.SearchPage"
             Title="Search"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Search Bar -->
        <Border Grid.Row="0"
                Margin="15,15,15,10"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="#242424">
            <SearchBar x:Name="SearchBarControl"
                       Placeholder="¿Qué quieres escuchar?"
                       Text="{Binding SearchQuery}"
                       SearchCommand="{Binding SearchCommand}"
                       TextColor="White"
                       PlaceholderColor="#B3B3B3"
                       CancelButtonColor="White" />
        </Border>

        <!-- Estado inicial: búsquedas recientes O invitación a buscar -->
        <Grid Grid.Row="1" IsVisible="{Binding ShowInitialPrompt}">

            <!-- Sin búsquedas recientes: prompt genérico -->
            <StackLayout IsVisible="{Binding HasNoRecentQueries}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Spacing="10"
                         Padding="40,0">
                <Label Text="&#x1F50E;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
                <Label Text="Busca tu música favorita"
                       TextColor="#B3B3B3"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </StackLayout>

            <!-- Con búsquedas recientes: lista de chips -->
            <VerticalStackLayout IsVisible="{Binding HasRecentQueries}" Margin="15,16">

                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                    <Label Grid.Column="0"
                           Text="Búsquedas recientes"
                           TextColor="White" FontSize="16" FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Limpiar"
                            TextColor="#B3B3B3" FontSize="13"
                            BackgroundColor="Transparent"
                            BorderColor="Transparent"
                            Padding="0"
                            Command="{Binding ClearRecentQueriesCommand}" />
                </Grid>

                <CollectionView ItemsSource="{Binding RecentQueries}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=SelectRecentQueryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto, *, Auto" Padding="6,8">
                                    <Label Grid.Column="0"
                                           Text="&#x21BA;"
                                           TextColor="#B3B3B3" FontSize="18"
                                           VerticalOptions="Center"
                                           Margin="0,0,14,0" />
                                    <Label Grid.Column="1"
                                           Text="{Binding .}"
                                           TextColor="White" FontSize="15"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="2"
                                           Text="&#x2197;"
                                           TextColor="#535353" FontSize="16"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

        </Grid>

        <!-- Spinner de carga -->
        <StackLayout Grid.Row="1"
                     IsVisible="{Binding IsBusy}"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="#1DB954"
                               WidthRequest="40"
                               HeightRequest="40" />
            <Label Text="Buscando..."
                   TextColor="#B3B3B3"
                   FontSize="14"
                   HorizontalOptions="Center" />
        </StackLayout>

        <!-- Sin resultados -->
        <StackLayout Grid.Row="1"
                     IsVisible="{Binding HasNoResults}"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="10"
                     Padding="40,0">
            <Label Text="&#x1F614;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
            <Label Text="Sin resultados"
                   TextColor="#B3B3B3"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Intenta con otro término de búsqueda"
                   TextColor="#535353"
                   FontSize="14"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </StackLayout>

        <!-- Lista de resultados -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding SearchResults}"
                        SelectionMode="None"
                        Margin="10,0"
                        IsVisible="{Binding HasResults}"
                        skeleton:Skeleton.IsParent="True"
                        skeleton:Skeleton.IsBusy="{Binding IsBusy}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Track">
                    <Grid Padding="5,4">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=Player.PlayTrackCommand}"
                                CommandParameter="{Binding .}"
                                Tapped="OnTrackTapped"/>
                        </Grid.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto, *, Auto" BackgroundColor="Transparent" Padding="10">
                            <!-- Thumbnail -->
                            <Border Grid.Column="0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 6"
                                    WidthRequest="55"
                                    HeightRequest="55"
                                    Margin="0,0,14,0">
                                <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill"
                                       skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=IsBusy}"
                                       skeleton:Skeleton.BackgroundColor="#3E3E3E"/>
                            </Border>

                            <!-- Texto -->
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Title}"
                                       TextColor="White" FontAttributes="Bold" FontSize="15"
                                       MaxLines="1" LineBreakMode="TailTruncation"
                                       skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=IsBusy}"
                                       skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                                <Label Text="{Binding Uploader}"
                                       TextColor="#B3B3B3" FontSize="13"
                                       MaxLines="1" LineBreakMode="TailTruncation"
                                       skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=IsBusy}"
                                       skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            </StackLayout>

                            <!-- Añadir a playlist -->
                            <Button Grid.Column="2"
                                    Text="+"
                                    TextColor="#B3B3B3" FontSize="22"
                                    BackgroundColor="Transparent" BorderColor="Transparent"
                                    WidthRequest="40" HeightRequest="40" Padding="0"
                                    VerticalOptions="Center"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnAddToPlaylistClicked" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <views:MiniPlayerView Grid.Row="2" />
    </Grid>
</ContentPage>
