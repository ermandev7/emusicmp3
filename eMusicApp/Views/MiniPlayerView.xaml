<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="eMusicApp.Views.MiniPlayerView">
    
    <Border Margin="15,0,15,15"
            StrokeThickness="1"
            Stroke="#33FFFFFF"
            StrokeShape="RoundRectangle 20"
            IsVisible="{Binding Player.HasCurrentTrack}"
            BackgroundColor="#282828">

        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnMiniPlayerTapped" />
        </Border.GestureRecognizers>

        <Grid RowDefinitions="Auto, 3" RowSpacing="0">

            <Grid Grid.Row="0" Padding="10,10,15,10" ColumnDefinitions="Auto, *, Auto, Auto">
                <!-- Thumbnail -->
                <Border Grid.Column="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        WidthRequest="50"
                        HeightRequest="50"
                        Margin="0,0,12,0">
                    <Image Source="{Binding Player.CurrentTrack.ThumbnailUrl}"
                           Aspect="AspectFill" />
                </Border>

                <!-- Track Info -->
                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding Player.CurrentTrack.Title}"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="14"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                    <Label Text="{Binding Player.CurrentTrack.Uploader}"
                           TextColor="#B3B3B3"
                           FontSize="12"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           IsVisible="{Binding Player.ShowPlayButton}" />
                    <Label Text="Cargando..."
                           TextColor="#1DB954"
                           FontSize="12"
                           IsVisible="{Binding Player.ShowLoadingSpinner}" />
                </StackLayout>

                <!-- Spinner de buffering / Play-Pause -->
                <Grid Grid.Column="2" WidthRequest="36" HeightRequest="36" Margin="0,0,10,0">
                    <ActivityIndicator IsRunning="{Binding Player.ShowLoadingSpinner}"
                                       IsVisible="{Binding Player.ShowLoadingSpinner}"
                                       Color="#1DB954"
                                       WidthRequest="24" HeightRequest="24"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                    <ImageButton Source="{Binding Player.PlayPauseImage}"
                                 Command="{Binding Player.TogglePlaybackCommand}"
                                 IsVisible="{Binding Player.ShowPlayButton}"
                                 WidthRequest="30" HeightRequest="30"
                                 BackgroundColor="Transparent"
                                 VerticalOptions="Center" Padding="0" />
                </Grid>

                <!-- Next Button -->
                <ImageButton Grid.Column="3"
                             Source="next.png"
                             Command="{Binding Player.NextTrackCommand}"
                             WidthRequest="30" HeightRequest="30"
                             BackgroundColor="Transparent"
                             VerticalOptions="Center"
                             Padding="0" />
            </Grid>

            <!-- Barra de progreso estilo Spotify -->
            <ProgressBar Grid.Row="1"
                         Progress="{Binding Player.ProgressFraction}"
                         ProgressColor="#1DB954"
                         BackgroundColor="#404040"
                         HeightRequest="3"
                         Margin="0"
                         VerticalOptions="EndAndExpand" />

        </Grid>
    </Border>
</ContentView>
