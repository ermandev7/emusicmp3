<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             x:Class="eMusicApp.Views.FullPlayerPage"
             BackgroundColor="#121212">

    <!-- Background gradient set dynamically from album art in code-behind -->

    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="20">
        <Grid.GestureRecognizers>
            <SwipeGestureRecognizer Direction="Down" Command="{Binding MinimizeCommand}" />
        </Grid.GestureRecognizers>
        
        <!-- Top Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,10,0,30">
            <ImageButton Grid.Column="0" 
                         Source="chevron_down.png" 
                         BackgroundColor="Transparent"
                         WidthRequest="40" HeightRequest="40"
                         Padding="10"
                         Command="{Binding MinimizeCommand}" />
            
            <Label Grid.Column="1" 
                   Text="REPRODUCIENDO AHORA" 
                   TextColor="White" 
                   FontSize="12" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" />
                   
            <HorizontalStackLayout Grid.Column="2" Spacing="0">
                <!-- Sleep timer -->
                <Button Text="⏱"
                        TextColor="{Binding Player.SleepTimerColor}"
                        FontSize="18"
                        BackgroundColor="Transparent" BorderColor="Transparent"
                        WidthRequest="40" HeightRequest="40" Padding="0"
                        Clicked="OnSleepTimerClicked" />
                <!-- Queue -->
                <Button Text="☰"
                        TextColor="#B3B3B3"
                        FontSize="20"
                        BackgroundColor="Transparent" BorderColor="Transparent"
                        WidthRequest="40" HeightRequest="40" Padding="0"
                        Clicked="OnQueueClicked" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Album Art -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="#2A2A2A"
                    Shadow="{Shadow Brush=Black, Offset='0,10', Radius=20, Opacity=0.5}">
                <Image Source="{Binding Player.CurrentTrack.HqThumbnailUrl}" Aspect="AspectFill" />
            </Border>
            <!-- Overlay de carga sobre la portada -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="#99000000"
                    IsVisible="{Binding Player.IsBuffering}">
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                    <ActivityIndicator IsRunning="{Binding Player.IsBuffering}"
                                       Color="#1DB954"
                                       WidthRequest="48" HeightRequest="48" />
                    <Label Text="Cargando..."
                           TextColor="#B3B3B3" FontSize="14"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Track Info -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <StackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="{Binding Player.CurrentTrack.Title}"
                       TextColor="White"
                       FontSize="24"
                       FontAttributes="Bold"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding Player.CurrentTrack.Uploader}"
                       TextColor="#B3B3B3"
                       FontSize="16"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
            </StackLayout>
            <Button Grid.Column="1"
                    Text="⬇"
                    TextColor="{Binding Player.DownloadButtonColor}"
                    FontSize="32"
                    BackgroundColor="Transparent"
                    BorderColor="Transparent"
                    Padding="0"
                    WidthRequest="52" HeightRequest="52"
                    VerticalOptions="Center"
                    Command="{Binding Player.DownloadTrackCommand}"
                    CommandParameter="{Binding Player.CurrentTrack}" />
        </Grid>

        <!-- Controls -->
        <Grid Grid.Row="3" RowDefinitions="Auto, Auto, Auto, Auto" Margin="0,0,0,30">
            <!-- Progress Section -->
            <StackLayout Grid.Row="0" Margin="0,0,0,20">
                <Slider x:Name="AudioSlider"
                        Value="{Binding Player.ProgressFraction, Mode=OneWay}"
                        Maximum="1"
                        MinimumTrackColor="#1DB954"
                        MaximumTrackColor="#4DFFFFFF"
                        ThumbColor="White"
                        DragStarted="OnSliderDragStarted"
                        DragCompleted="OnSliderDragCompleted" />
                <Grid ColumnDefinitions="*, *">
                    <Label Grid.Column="0" Text="{Binding Player.PositionText}" TextColor="#B3B3B3" FontSize="12" HorizontalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding Player.RemainingTimeText}" TextColor="#B3B3B3" FontSize="12" HorizontalOptions="End" />
                </Grid>
            </StackLayout>
            
            <!-- Radio + Crossfade -->
            <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,12,0,0">
                <Button Grid.Column="0"
                        Text="📻 Radio"
                        TextColor="{Binding Player.RadioColor}"
                        FontSize="13"
                        BackgroundColor="Transparent" BorderColor="Transparent"
                        Padding="0" HeightRequest="34"
                        HorizontalOptions="Center"
                        Command="{Binding Player.ToggleRadioCommand}" />
                <Button Grid.Column="1"
                        Text="{Binding Player.CrossfadeLabel}"
                        TextColor="{Binding Player.CrossfadeColor}"
                        FontSize="13"
                        BackgroundColor="Transparent" BorderColor="Transparent"
                        Padding="0" HeightRequest="34"
                        HorizontalOptions="Center"
                        Command="{Binding Player.CycleCrossfadeCommand}" />
            </Grid>

            <!-- Sleep timer countdown -->
            <Label Grid.Row="3"
                   Text="{Binding Player.SleepTimerText}"
                   IsVisible="{Binding Player.IsSleepTimerActive}"
                   TextColor="#1DB954" FontSize="12"
                   HorizontalOptions="Center"
                   Margin="0,6,0,0" />

            <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto, *" HorizontalOptions="FillAndExpand">

                <!-- Shuffle -->
                <Button Grid.Column="0"
                        Text="⇌"
                        TextColor="{Binding Player.ShuffleColor}"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        Padding="0"
                        WidthRequest="44" HeightRequest="44"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        Command="{Binding Player.ToggleShuffleCommand}" />

                <ImageButton Grid.Column="1"
                             Source="previous.png"
                             BackgroundColor="Transparent"
                             WidthRequest="40"
                             HeightRequest="40"
                             VerticalOptions="Center"
                             Padding="5"
                             Margin="10,0"
                             Command="{Binding Player.PreviousTrackCommand}" />

                <!-- Botón Play/Pause con spinner de carga superpuesto -->
                <Grid Grid.Column="2" WidthRequest="70" HeightRequest="70"
                      VerticalOptions="Center" Margin="20,0">
                    <ImageButton Source="{Binding Player.PlayPauseImage}"
                                 Command="{Binding Player.TogglePlaybackCommand}"
                                 BackgroundColor="#1DB954"
                                 CornerRadius="35"
                                 WidthRequest="70"
                                 HeightRequest="70"
                                 Padding="18" />
                    <Border BackgroundColor="#1DB954"
                            StrokeShape="RoundRectangle 35"
                            StrokeThickness="0"
                            WidthRequest="70"
                            HeightRequest="70"
                            Padding="0"
                            IsVisible="{Binding Player.ShowLoadingSpinner}">
                        <ActivityIndicator IsRunning="{Binding Player.ShowLoadingSpinner}"
                                           Color="White"
                                           WidthRequest="28"
                                           HeightRequest="28"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                    </Border>
                </Grid>

                <ImageButton Grid.Column="3"
                             Source="next.png"
                             BackgroundColor="Transparent"
                             WidthRequest="40"
                             HeightRequest="40"
                             VerticalOptions="Center"
                             Padding="5"
                             Margin="10,0"
                             Command="{Binding Player.NextTrackCommand}" />

                <!-- Repeat -->
                <Button Grid.Column="4"
                        Text="{Binding Player.RepeatIcon}"
                        TextColor="{Binding Player.RepeatColor}"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        Padding="0"
                        WidthRequest="44" HeightRequest="44"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Command="{Binding Player.CycleRepeatCommand}" />
            </Grid>
        </Grid>
        
    </Grid>
</ContentPage>
