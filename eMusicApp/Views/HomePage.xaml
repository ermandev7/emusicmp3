<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             xmlns:models="clr-namespace:eMusicApp.Models"
             xmlns:views="clr-namespace:eMusicApp.Views"
             xmlns:skeleton="clr-namespace:Maui.Skeleton;assembly=Maui.Skeleton"
             x:Class="eMusicApp.Views.HomePage"
             Title="Home"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Margin="16,24,16,12">
            <Label Text="Escuchados Recientes" TextColor="White" FontSize="22" FontAttributes="Bold" />
        </HorizontalStackLayout>

        <!-- Empty state: sin historial -->
        <StackLayout Grid.Row="1"
                     IsVisible="{Binding HasNoHistory}"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="12"
                     Padding="40,0">
            <Label Text="&#x266A;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
            <Label Text="Sin historial aún"
                   TextColor="#B3B3B3"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Busca una canción y empieza a escuchar"
                   TextColor="#535353"
                   FontSize="14"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </StackLayout>

        <!-- Lista de historial (2 columnas) -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding RecentTracks}"
                        SelectionMode="None"
                        Margin="10,0"
                        IsVisible="{Binding HasHistory}"
                        skeleton:Skeleton.IsParent="True"
                        skeleton:Skeleton.IsBusy="{Binding IsBusy}">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Track">
                    <Grid>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=Player.PlayTrackCommand}"
                                CommandParameter="{Binding .}"/>
                        </Grid.GestureRecognizers>

                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                BackgroundColor="#282828"
                                HeightRequest="60">
                            <Grid ColumnDefinitions="60, *">
                                <!-- Thumbnail con skeleton -->
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8 0 0 8"
                                        skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=IsBusy}"
                                        skeleton:Skeleton.BackgroundColor="#3E3E3E">
                                    <Image Source="{Binding ThumbnailUrl}"
                                           Aspect="AspectFill" />
                                </Border>

                                <!-- Título con skeleton -->
                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="12"
                                       VerticalOptions="Center"
                                       Margin="10,0,6,0"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=IsBusy}"
                                       skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <views:MiniPlayerView Grid.Row="2" />
    </Grid>
</ContentPage>
