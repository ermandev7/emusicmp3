<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="eMusicApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:eMusicApp"
    xmlns:views="clr-namespace:eMusicApp.Views"
    Title="eMusicApp"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="#000000"
    Shell.TabBarTitleColor="White"
    Shell.TabBarUnselectedColor="#B3B3B3">

    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="HomePage" />
        </Tab>
        <Tab Title="Search" Icon="search.png">
            <ShellContent ContentTemplate="{DataTemplate views:SearchPage}" Route="SearchPage" />
        </Tab>
        <Tab Title="Library" Icon="library_music.png">
            <ShellContent ContentTemplate="{DataTemplate views:LibraryPage}" Route="LibraryPage" />
        </Tab>
    </TabBar>

</Shell>
