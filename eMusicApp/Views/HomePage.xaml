<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             xmlns:models="clr-namespace:eMusicApp.Models"
             xmlns:views="clr-namespace:eMusicApp.Views"
             xmlns:skeleton="clr-namespace:Maui.Skeleton;assembly=Maui.Skeleton"
             x:Class="eMusicApp.Views.HomePage"
             Title="Inicio"
             BackgroundColor="#121212">

    <RefreshView Command="{Binding LoadRecentTracksCommand}"
                 IsRefreshing="{Binding IsBusy}"
                 RefreshColor="#1DB954">

        <Grid RowDefinitions="*, Auto">

            <CollectionView Grid.Row="0"
                            ItemsSource="{Binding RecentTracks}"
                            SelectionMode="None"
                            Margin="10,0"
                            skeleton:Skeleton.IsParent="True"
                            skeleton:Skeleton.IsBusy="{Binding IsBusy}">

                <CollectionView.Header>
                    <StackLayout Spacing="4" Margin="6,20,6,16">
                        <Label Text="{Binding Greeting}"
                               TextColor="White" FontSize="26" FontAttributes="Bold" />
                        <Label Text="Escuchados Recientemente"
                               IsVisible="{Binding HasHistory}"
                               TextColor="#B3B3B3" FontSize="14"
                               Margin="0,8,0,0" />
                    </StackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <StackLayout IsVisible="{Binding HasNoHistory}"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="12" Padding="40,20">
                        <Label Text="&#x266A;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
                        <Label Text="Sin historial aun"
                               TextColor="#B3B3B3" FontSize="18" FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Busca una cancion y empieza a escuchar"
                               TextColor="#535353" FontSize="14"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Track">
                        <Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=Player.PlayTrackCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#282828"
                                    HeightRequest="64">
                                <Grid ColumnDefinitions="64, *">
                                    <Border Grid.Column="0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8 0 0 8"
                                            skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=IsBusy}"
                                            skeleton:Skeleton.BackgroundColor="#3E3E3E">
                                        <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                    </Border>

                                    <StackLayout Grid.Column="1" VerticalOptions="Center"
                                                 Spacing="1" Margin="10,0,6,0">
                                        <Label Text="{Binding Title}"
                                               TextColor="White" FontAttributes="Bold" FontSize="12"
                                               MaxLines="1" LineBreakMode="TailTruncation"
                                               skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=IsBusy}"
                                               skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                                        <Label Text="{Binding Uploader}"
                                               TextColor="#808080" FontSize="10"
                                               MaxLines="1" LineBreakMode="TailTruncation" />
                                    </StackLayout>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <views:MiniPlayerView Grid.Row="1" />
        </Grid>

    </RefreshView>
</ContentPage>
