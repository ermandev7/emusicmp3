<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             xmlns:models="clr-namespace:eMusicApp.Models"
             xmlns:views="clr-namespace:eMusicApp.Views"
             xmlns:skeleton="clr-namespace:Maui.Skeleton;assembly=Maui.Skeleton"
             x:Class="eMusicApp.Views.HomePage"
             Title="Inicio"
             BackgroundColor="#121212">

    <RefreshView Command="{Binding LoadRecentTracksCommand}"
                 IsRefreshing="{Binding IsBusy}"
                 RefreshColor="#1DB954">

        <Grid RowDefinitions="*, Auto">

            <ScrollView Grid.Row="0">
                <StackLayout Spacing="0" Padding="14,20,14,10">

                    <!-- Saludo -->
                    <Label Text="{Binding Greeting}"
                           TextColor="White" FontSize="26" FontAttributes="Bold"
                           Margin="2,0,0,16" />

                    <!-- ═══ SKELETON LOADING ═══ -->
                    <StackLayout IsVisible="{Binding IsBusy}" Spacing="0"
                                 skeleton:Skeleton.IsParent="True"
                                 skeleton:Skeleton.IsBusy="True"
                                 skeleton:Skeleton.BackgroundColor="#3E3E3E">

                        <!-- Skeleton géneros: 6 filas de 2 -->
                        <FlexLayout Wrap="Wrap" JustifyContent="SpaceBetween">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#282828"
                                    HeightRequest="56" Margin="0,0,0,10" FlexLayout.Basis="48%"
                                    skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                        </FlexLayout>

                        <!-- Skeleton label recientes -->
                        <BoxView BackgroundColor="#282828" HeightRequest="14" WidthRequest="180"
                                 HorizontalOptions="Start" Margin="2,20,0,10" CornerRadius="4"
                                 skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />

                        <!-- Skeleton tracks: 3 filas de 2 -->
                        <Grid ColumnDefinitions="*, *" RowDefinitions="64,64,64"
                              ColumnSpacing="10" RowSpacing="10">
                            <Border Grid.Row="0" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#282828" skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border Grid.Row="0" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#282828" skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border Grid.Row="1" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#282828" skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border Grid.Row="1" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#282828" skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border Grid.Row="2" Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#282828" skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                            <Border Grid.Row="2" Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#282828" skeleton:Skeleton.IsBusy="True" skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                        </Grid>
                    </StackLayout>

                    <!-- ═══ GÉNEROS ═══ -->
                    <FlexLayout Wrap="Wrap"
                                JustifyContent="SpaceBetween"
                                IsVisible="{Binding IsNotBusy}"
                                BindableLayout.ItemsSource="{Binding Genres}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="#282828"
                                        HeightRequest="56"
                                        Margin="0,0,0,10"
                                        Padding="0"
                                        WidthRequest="-1"
                                        FlexLayout.Basis="48%">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=PlayGenreCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="56, *">
                                        <BoxView Grid.Column="0"
                                                 Color="#1DB954"
                                                 CornerRadius="12,0,12,0"
                                                 WidthRequest="56" HeightRequest="56" />
                                        <Label Grid.Column="0"
                                               Text="&#x266B;"
                                               TextColor="White"
                                               FontSize="22"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding .}"
                                               TextColor="White"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"
                                               Margin="12,0,8,0"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation"
                                               TextTransform="Uppercase" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- ═══ ESCUCHADOS RECIENTEMENTE ═══ -->
                    <Label Text="Escuchados Recientemente"
                           IsVisible="{Binding HasHistory}"
                           TextColor="#B3B3B3" FontSize="14"
                           Margin="2,20,0,10" />

                    <CollectionView ItemsSource="{Binding RecentTracks}"
                                    SelectionMode="None"
                                    IsVisible="{Binding HasHistory}">

                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2"
                                             HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Track">
                                <Grid>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=Player.PlayTrackCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            BackgroundColor="#282828"
                                            HeightRequest="64">
                                        <Grid ColumnDefinitions="64, *">
                                            <Border Grid.Column="0"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8 0 0 8">
                                                <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                            </Border>

                                            <StackLayout Grid.Column="1" VerticalOptions="Center"
                                                         Spacing="1" Margin="10,0,6,0">
                                                <Label Text="{Binding Title}"
                                                       TextColor="White" FontAttributes="Bold" FontSize="12"
                                                       MaxLines="1" LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Uploader}"
                                                       TextColor="#808080" FontSize="10"
                                                       MaxLines="1" LineBreakMode="TailTruncation" />
                                            </StackLayout>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty state -->
                    <StackLayout IsVisible="{Binding HasNoHistory}"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="12" Padding="40,20">
                        <Label Text="&#x266A;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
                        <Label Text="Sin historial aun"
                               TextColor="#B3B3B3" FontSize="18" FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Busca una cancion y empieza a escuchar"
                               TextColor="#535353" FontSize="14"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </StackLayout>

                </StackLayout>
            </ScrollView>

            <views:MiniPlayerView Grid.Row="1" />
        </Grid>

    </RefreshView>
</ContentPage>
