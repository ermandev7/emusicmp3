<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             xmlns:models="clr-namespace:eMusicApp.Models"
             xmlns:views="clr-namespace:eMusicApp.Views"
             xmlns:skeleton="clr-namespace:Maui.Skeleton;assembly=Maui.Skeleton"
             x:Class="eMusicApp.Views.LibraryPage"
             Title="Library"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, Auto, *, Auto">

        <!-- Header y tabs -->
        <StackLayout Grid.Row="0" Margin="16,20,16,0" Spacing="14">
            <Grid ColumnDefinitions="*, Auto">
                <Label Grid.Column="0" Text="Tu Biblioteca" TextColor="White" FontSize="24" FontAttributes="Bold" VerticalOptions="Center"/>
                <!-- Botón Nueva Playlist: solo visible en tab Playlists -->
                <Button Grid.Column="1"
                        Text="+"
                        TextColor="#1DB954" FontSize="26"
                        BackgroundColor="Transparent" BorderColor="Transparent"
                        WidthRequest="44" HeightRequest="44" Padding="0"
                        IsVisible="{Binding ShowPlaylists}"
                        Clicked="OnCreatePlaylistClicked" />
            </Grid>

            <HorizontalStackLayout Spacing="10">
                <!-- Tab Favoritos -->
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 18"
                        Padding="0"
                        HeightRequest="36" WidthRequest="110">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowFavorites}" Value="True">
                            <Setter Property="BackgroundColor" Value="#1DB954" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowFavorites}" Value="False">
                            <Setter Property="BackgroundColor" Value="#2A2A2A" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="Favoritos" />
                    </Border.GestureRecognizers>
                    <Label Text="Favoritos" HorizontalOptions="Center" VerticalOptions="Center"
                           FontSize="13" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding ShowFavorites}" Value="True">
                                <Setter Property="TextColor" Value="Black" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding ShowFavorites}" Value="False">
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Tab Descargas -->
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 18"
                        Padding="0"
                        HeightRequest="36" WidthRequest="110">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowDownloads}" Value="True">
                            <Setter Property="BackgroundColor" Value="#1DB954" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowDownloads}" Value="False">
                            <Setter Property="BackgroundColor" Value="#2A2A2A" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="Descargas" />
                    </Border.GestureRecognizers>
                    <Label Text="Descargas" HorizontalOptions="Center" VerticalOptions="Center"
                           FontSize="13" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding ShowDownloads}" Value="True">
                                <Setter Property="TextColor" Value="Black" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding ShowDownloads}" Value="False">
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
                <!-- Tab Playlists -->
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 18"
                        Padding="0"
                        HeightRequest="36" WidthRequest="110">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowPlaylists}" Value="True">
                            <Setter Property="BackgroundColor" Value="#1DB954" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowPlaylists}" Value="False">
                            <Setter Property="BackgroundColor" Value="#2A2A2A" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="Playlists" />
                    </Border.GestureRecognizers>
                    <Label Text="Playlists" HorizontalOptions="Center" VerticalOptions="Center"
                           FontSize="13" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding ShowPlaylists}" Value="True">
                                <Setter Property="TextColor" Value="Black" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding ShowPlaylists}" Value="False">
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

            </HorizontalStackLayout>
        </StackLayout>

        <!-- Barra de progreso de descarga (se muestra solo cuando hay descarga activa) -->
        <StackLayout Grid.Row="1"
                     IsVisible="{Binding IsDownloading}"
                     Margin="16,10,16,0"
                     Spacing="4">
            <Label Text="{Binding DownloadProgressText}"
                   TextColor="#1DB954" FontSize="12" />
            <ProgressBar Progress="{Binding DownloadProgress}"
                         ProgressColor="#1DB954"
                         BackgroundColor="#2A2A2A"
                         HeightRequest="3" />
        </StackLayout>

        <!-- Contenido principal -->
        <Grid Grid.Row="2" Margin="10,8,10,0">

            <!-- ── FAVORITOS ── -->
            <!-- Empty state -->
            <StackLayout IsVisible="{Binding HasNoFavorites}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Spacing="10" Padding="40,0">
                <Label Text="&#x2665;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
                <Label Text="Sin favoritos aún"
                       TextColor="#B3B3B3" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Toca el corazón en una canción para guardarla"
                       TextColor="#535353" FontSize="14"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            </StackLayout>

            <!-- Lista de favoritos -->
            <CollectionView ItemsSource="{Binding LikedSongs}"
                            SelectionMode="None"
                            IsVisible="{Binding ShowFavorites}"
                            skeleton:Skeleton.IsParent="True"
                            skeleton:Skeleton.IsBusy="{Binding IsBusy}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Track">
                        <Grid Padding="5,4">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=Player.PlayTrackCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Grid.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *, Auto, Auto" BackgroundColor="Transparent" Padding="10">
                                <Border Grid.Column="0"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 6"
                                        WidthRequest="52" HeightRequest="52" Margin="0,0,14,0">
                                    <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill"
                                           skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=IsBusy}"
                                           skeleton:Skeleton.BackgroundColor="#3E3E3E"/>
                                </Border>

                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Title}" TextColor="White" FontAttributes="Bold" FontSize="15"
                                           MaxLines="1" LineBreakMode="TailTruncation"
                                           skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=IsBusy}"
                                           skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                                    <Label Text="{Binding Uploader}" TextColor="#B3B3B3" FontSize="13"
                                           MaxLines="1" LineBreakMode="TailTruncation"
                                           skeleton:Skeleton.IsBusy="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=IsBusy}"
                                           skeleton:Skeleton.BackgroundColor="#3E3E3E" />
                                </StackLayout>

                                <!-- Añadir a playlist -->
                                <Button Grid.Column="2"
                                        Text="+"
                                        TextColor="#B3B3B3" FontSize="22"
                                        BackgroundColor="Transparent" BorderColor="Transparent"
                                        WidthRequest="36" HeightRequest="36" Padding="0"
                                        VerticalOptions="Center"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnAddToPlaylistClicked" />

                                <!-- Quitar favorito -->
                                <ImageButton Grid.Column="3"
                                             Source="heart_filled.png"
                                             BackgroundColor="Transparent"
                                             WidthRequest="30" HeightRequest="30" Padding="5"
                                             VerticalOptions="Center"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=RemoveFavoriteCommand}"
                                             CommandParameter="{Binding .}" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ── DESCARGAS ── -->
            <!-- Empty state -->
            <StackLayout IsVisible="{Binding HasNoDownloads}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Spacing="10" Padding="40,0">
                <Label Text="&#x2B07;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
                <Label Text="Sin descargas"
                       TextColor="#B3B3B3" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Toca el ícono de descarga en una canción para escucharla sin internet"
                       TextColor="#535353" FontSize="14"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            </StackLayout>

            <!-- Lista de descargas -->
            <CollectionView ItemsSource="{Binding DownloadedSongs}"
                            SelectionMode="None"
                            IsVisible="{Binding ShowDownloads}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Track">
                        <Grid Padding="5,4">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=Player.PlayTrackCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Grid.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *, Auto" BackgroundColor="Transparent" Padding="10">
                                <Border Grid.Column="0"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 6"
                                        WidthRequest="52" HeightRequest="52" Margin="0,0,14,0">
                                    <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                </Border>

                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <!-- Título en verde para indicar offline -->
                                    <Label Text="{Binding Title}"
                                           TextColor="#1DB954" FontAttributes="Bold" FontSize="15"
                                           MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Uploader}"
                                           TextColor="#B3B3B3" FontSize="13"
                                           MaxLines="1" LineBreakMode="TailTruncation" />
                                </StackLayout>

                                <!-- Borrar descarga -->
                                <ImageButton Grid.Column="2"
                                             Source="trash.png"
                                             BackgroundColor="Transparent"
                                             WidthRequest="30" HeightRequest="30" Padding="5"
                                             VerticalOptions="Center"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=DeleteDownloadCommand}"
                                             CommandParameter="{Binding .}" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ── PLAYLISTS ── -->
            <!-- Empty state -->
            <StackLayout IsVisible="{Binding HasNoPlaylists}"
                         VerticalOptions="Center" HorizontalOptions="Center"
                         Spacing="10" Padding="40,0">
                <Label Text="&#x1F3B6;" FontSize="48" HorizontalOptions="Center" TextColor="#535353" />
                <Label Text="Sin playlists"
                       TextColor="#B3B3B3" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Toca + para crear tu primera playlist"
                       TextColor="#535353" FontSize="14"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            </StackLayout>

            <!-- Grid de playlists -->
            <CollectionView ItemsSource="{Binding Playlists}"
                            SelectionMode="None"
                            IsVisible="{Binding ShowPlaylists}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="10" VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Playlist">
                        <Grid Padding="4,0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnPlaylistTapped"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout Spacing="6">
                                <!-- Cover art o placeholder -->
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="140"
                                        BackgroundColor="#2A2A2A">
                                    <Grid>
                                        <Image Source="{Binding CoverUrl}" Aspect="AspectFill"
                                               IsVisible="{Binding HasCover}" />
                                        <Label Text="&#x1F3B5;"
                                               FontSize="48"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               TextColor="#535353"
                                               IsVisible="{Binding HasNoCover}" />
                                    </Grid>
                                </Border>

                                <StackLayout Padding="2,0" Spacing="2">
                                    <Label Text="{Binding Name}"
                                           TextColor="White" FontAttributes="Bold" FontSize="13"
                                           MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding TrackCountText}"
                                           TextColor="#B3B3B3" FontSize="11" />
                                </StackLayout>

                                <!-- Eliminar playlist -->
                                <Button Text="Eliminar"
                                        TextColor="#535353" FontSize="11"
                                        BackgroundColor="Transparent" BorderColor="Transparent"
                                        Padding="0" HeightRequest="28" HorizontalOptions="Start"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnDeletePlaylistClicked" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <views:MiniPlayerView Grid.Row="3" />
    </Grid>
</ContentPage>
