<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="eMusicApp.Views.UserSetupPage"
             Title="Bienvenido"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*, Auto, *" Padding="40,0">

        <!-- Logo / Titulo -->
        <StackLayout Grid.Row="0" VerticalOptions="End" HorizontalOptions="Center" Spacing="8">
            <Label Text="eMusicApp"
                   TextColor="#1DB954"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Tu musica, en cualquier lugar"
                   TextColor="#B3B3B3"
                   FontSize="16"
                   HorizontalOptions="Center"
                   Margin="0,0,0,30" />
        </StackLayout>

        <!-- Campo nombre -->
        <StackLayout Grid.Row="1" Spacing="16" VerticalOptions="Center">
            <Label Text="Como te llamas?"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Border StrokeThickness="1"
                    Stroke="#333333"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#1E1E1E"
                    Padding="12,4">
                <Entry x:Name="NameEntry"
                       Placeholder="Tu nombre"
                       TextColor="White"
                       PlaceholderColor="#666666"
                       FontSize="18"
                       HorizontalTextAlignment="Center"
                       BackgroundColor="Transparent"
                       Completed="OnEntryCompleted" />
            </Border>

            <Button Text="Entrar"
                    BackgroundColor="#1DB954"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50"
                    Clicked="OnEntrarClicked" />
        </StackLayout>

    </Grid>

</ContentPage>
