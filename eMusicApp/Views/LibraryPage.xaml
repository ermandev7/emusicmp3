<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             xmlns:models="clr-namespace:eMusicApp.Models"
             xmlns:views="clr-namespace:eMusicApp.Views"
             x:Class="eMusicApp.Views.LibraryPage"
             Title="Biblioteca"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Header -->
        <Label Grid.Row="0" Text="Descargas" TextColor="White" FontSize="24"
               FontAttributes="Bold" Margin="16,20,16,12" />

        <!-- Descargas list -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding DownloadedSongs}"
                        SelectionMode="None"
                        Margin="10,0">
            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center"
                             Spacing="10" Padding="40,0">
                    <Label Text="Sin descargas"
                           TextColor="#B3B3B3" FontSize="18" FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Label Text="Descarga canciones desde el reproductor para escuchar offline"
                           TextColor="#535353" FontSize="14"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                </StackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Track">
                    <Grid Padding="5,4">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=Player.PlayTrackCommand}"
                                CommandParameter="{Binding .}"/>
                        </Grid.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="10">
                            <Border Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 6"
                                    WidthRequest="52" HeightRequest="52" Margin="0,0,14,0">
                                <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Title}" TextColor="White" FontAttributes="Bold" FontSize="15"
                                       MaxLines="1" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Uploader}" TextColor="#B3B3B3" FontSize="13"
                                       MaxLines="1" LineBreakMode="TailTruncation" />
                            </StackLayout>
                            <ImageButton Grid.Column="2" Source="trash.png"
                                         BackgroundColor="Transparent" WidthRequest="28" HeightRequest="28"
                                         Padding="5" VerticalOptions="Center"
                                         Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=DeleteDownloadCommand}"
                                         CommandParameter="{Binding .}" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Download progress -->
        <Grid Grid.Row="1" VerticalOptions="End" Margin="16,0,16,10"
              IsVisible="{Binding IsDownloading}">
            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10"
                    BackgroundColor="#1E1E1E" Padding="14,10">
                <HorizontalStackLayout Spacing="12">
                    <ActivityIndicator IsRunning="True" Color="#1DB954"
                                       WidthRequest="20" HeightRequest="20" />
                    <Label Text="{Binding DownloadProgressText}"
                           TextColor="#1DB954" FontSize="13" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <views:MiniPlayerView Grid.Row="2" />
    </Grid>
</ContentPage>
