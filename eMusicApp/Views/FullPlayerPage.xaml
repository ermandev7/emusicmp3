<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eMusicApp.ViewModels"
             x:Class="eMusicApp.Views.FullPlayerPage"
             BackgroundColor="#121212">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#282828" Offset="0.0" />
            <GradientStop Color="#121212" Offset="0.5" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="20">
        <Grid.GestureRecognizers>
            <SwipeGestureRecognizer Direction="Down" Command="{Binding MinimizeCommand}" />
        </Grid.GestureRecognizers>
        
        <!-- Top Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,10,0,30">
            <ImageButton Grid.Column="0" 
                         Source="chevron_down.png" 
                         BackgroundColor="Transparent"
                         WidthRequest="40" HeightRequest="40"
                         Padding="10"
                         Command="{Binding MinimizeCommand}" />
            
            <Label Grid.Column="1" 
                   Text="REPRODUCIENDO AHORA" 
                   TextColor="White" 
                   FontSize="12" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" />
                   
            <ContentView Grid.Column="2" WidthRequest="40" />
        </Grid>

        <!-- Album Art -->
        <Border Grid.Row="1" 
                StrokeThickness="0" 
                StrokeShape="RoundRectangle 8"
                Margin="0,0,0,30"
                BackgroundColor="#2A2A2A"
                Shadow="{Shadow Brush=Black, Offset='0,10', Radius=20, Opacity=0.5}">
            <Image Source="{Binding Player.CurrentTrack.ThumbnailUrl}" Aspect="AspectFill" />
        </Border>

        <!-- Track Info -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,20">
            <StackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="{Binding Player.CurrentTrack.Title}" 
                       TextColor="White" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       MaxLines="1" 
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding Player.CurrentTrack.Uploader}" 
                       TextColor="#B3B3B3" 
                       FontSize="16" 
                       MaxLines="1" 
                       LineBreakMode="TailTruncation" />
            </StackLayout>
            <ImageButton Grid.Column="1" 
                          Source="download.png" 
                          BackgroundColor="Transparent" 
                          WidthRequest="30" HeightRequest="30"
                          Margin="0,0,15,0"
                          VerticalOptions="Center" 
                          Command="{Binding Player.DownloadTrackCommand}"
                          CommandParameter="{Binding Player.CurrentTrack}" />
            <ImageButton Grid.Column="2" 
                          Source="heart_outline.png" 
                          BackgroundColor="Transparent" 
                          WidthRequest="30" HeightRequest="30"
                          VerticalOptions="Center"
                          Command="{Binding Player.ToggleFavoriteCommand}" />
        </Grid>

        <!-- Controls -->
        <Grid Grid.Row="3" RowDefinitions="Auto, Auto" Margin="0,0,0,30">
            <!-- Progress Section -->
            <StackLayout Grid.Row="0" Margin="0,0,0,20">
                <Slider x:Name="AudioSlider" 
                        Value="{Binding Player.Position, Mode=OneWay}" 
                        Maximum="{Binding Player.SliderMaximum, FallbackValue=100}" 
                        MinimumTrackColor="#1DB954" 
                        MaximumTrackColor="#4DFFFFFF" 
                        ThumbColor="White"
                        DragStarted="OnSliderDragStarted"
                        DragCompleted="OnSliderDragCompleted" />
                <Grid ColumnDefinitions="*, *">
                    <Label Grid.Column="0" Text="{Binding Player.PositionText}" TextColor="#B3B3B3" FontSize="12" HorizontalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding Player.RemainingTimeText}" TextColor="#B3B3B3" FontSize="12" HorizontalOptions="End" />
                </Grid>
            </StackLayout>
            
            <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto, *" HorizontalOptions="FillAndExpand">
                <ImageButton Grid.Column="1" 
                             Source="previous.png" 
                             BackgroundColor="Transparent" 
                             WidthRequest="40" 
                             HeightRequest="40" 
                             VerticalOptions="Center" 
                             Padding="5"
                             Margin="10,0" 
                             Command="{Binding Player.PreviousTrackCommand}" />
                
                <!-- Botón Play/Pause con spinner de carga superpuesto -->
                <Grid Grid.Column="2" WidthRequest="70" HeightRequest="70" 
                      VerticalOptions="Center" Margin="20,0">
                    <!-- Botón normal play/pause -->
                    <ImageButton Source="{Binding Player.PlayPauseImage}"
                                 Command="{Binding Player.TogglePlaybackCommand}"
                                 BackgroundColor="#1DB954"
                                 CornerRadius="35"
                                 WidthRequest="70"
                                 HeightRequest="70"
                                 Padding="18" />
                    <!-- Spinner de carga (se superpone cuando está buffering) -->
                    <Frame BackgroundColor="#1DB954"
                           CornerRadius="35"
                           WidthRequest="70"
                           HeightRequest="70"
                           IsClippedToBounds="True"
                           HasShadow="False"
                           Padding="0"
                           IsVisible="{Binding Player.ShowLoadingSpinner}">
                        <ActivityIndicator IsRunning="True"
                                           Color="White"
                                           WidthRequest="28"
                                           HeightRequest="28"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                    </Frame>
                </Grid>

                
                <ImageButton Grid.Column="3" 
                             Source="next.png" 
                             BackgroundColor="Transparent" 
                             WidthRequest="40" 
                             HeightRequest="40" 
                             VerticalOptions="Center" 
                             Padding="5"
                             Margin="10,0" 
                             Command="{Binding Player.NextTrackCommand}" />
            </Grid>
        </Grid>
        
    </Grid>
</ContentPage>
